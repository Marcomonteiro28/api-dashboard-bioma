{
  "name": "api-dashboard-bioma",
  "version": "1.0.0",
  "description": "API local Express + dashboard HTML que servem dados do BigQuery (Bioma CRM) para análise de funil de pré-vendas e vendas",
  "main": "server/src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/src/index.js",
    "dev": "node --watch server/src/index.js",
    "sync:meta": "node server/src/jobs/sync-meta.js",
    "sync:meta-images": "node server/src/jobs/sync-adimages.js",
    "apply:meta-views": "node server/src/jobs/apply-meta-views.js",
    "import:csv-deals": "node server/src/jobs/import-csv-deals.js",
    "sync:ac": "node server/src/jobs/sync-ac.js",
    "sync:gads": "node server/src/jobs/sync-gads.js",
    "sync:all": "npm run sync:ac && npm run sync:meta && npm run sync:gads && npm run apply:meta-views"
  },
  "keywords": [
    "bigquery",
    "crm",
    "dashboard",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^9.15.0"
  }
}
