# BigQuery / API
GCP_PROJECT_ID=kondado-bioma
BQ_DATASET=crm_marts
BQ_LOCATION=southamerica-east1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Server
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:3001
CACHE_TTL_MS=600000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Meta Marketing API (Fase A)
# Token NUNCA deve ser colado em chat — só direto neste arquivo.
# Gere em https://developers.facebook.com/apps/<APP_ID>/marketing-api/tools
# Token precisa de permissão ads_read no mínimo.
META_API_VERSION=v20.0
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXX
META_INSIGHTS_LOOKBACK_DAYS=30
# Dataset BQ para gravar tabelas meta_*. Recomendado: dataset proprio
# (nao o do Kondado) para evitar conflito de permissoes. Default: BQ_DATASET.
META_BQ_DATASET=bioma_meta

# ActiveCampaign API (Fase AC)
AC_API_URL=https://biomainc.api-us1.com
AC_API_TOKEN=
AC_BQ_DATASET=bioma_meta

# Google Ads API (Fase GAds)
# 1. Developer token: Tools & Settings → API Center na MCC RazConsulting
# 2. OAuth Client: console.cloud.google.com/apis/credentials → "OAuth 2.0 Client ID" tipo Desktop
# 3. Refresh token: rodar `node scripts/gads-refresh-token.mjs` (gera link, cola na URL, copia code)
# 4. Customer IDs: lista de contas filhas que vamos ler (separadas por virgula, podem ter hifen ou nao)
# 5. Login customer ID: o ID da MCC RazConsulting (sem hifens)
GADS_API_VERSION=v18
GADS_DEVELOPER_TOKEN=
GADS_OAUTH_CLIENT_ID=
GADS_OAUTH_CLIENT_SECRET=
GADS_REFRESH_TOKEN=
GADS_LOGIN_CUSTOMER_ID=
GADS_CUSTOMER_IDS=
GADS_INSIGHTS_LOOKBACK_DAYS=30
GADS_BQ_DATASET=bioma_meta

# Auth Google OAuth (Fase Cloud-D)
GOOGLE_CLIENT_ID=
ALLOWED_EMAIL_DOMAINS=razconsulting.com.br
ALLOWED_EMAILS=

# Internal job token (Cloud Scheduler → /jobs/*)
INTERNAL_JOB_TOKEN=
