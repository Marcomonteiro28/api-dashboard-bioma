# BigQuery / API
GCP_PROJECT_ID=kondado-bioma
BQ_DATASET=crm_marts
BQ_LOCATION=southamerica-east1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Server
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:3001
CACHE_TTL_MS=600000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Meta Marketing API (Fase A)
# Token NUNCA deve ser colado em chat — só direto neste arquivo.
# Gere em https://developers.facebook.com/apps/<APP_ID>/marketing-api/tools
# Token precisa de permissão ads_read no mínimo.
META_API_VERSION=v20.0
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXX
META_INSIGHTS_LOOKBACK_DAYS=30
